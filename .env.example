# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxx:password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# Auth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Microsoft Azure AD (SSO) — optionnel en dev
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Microsoft Graph API
MICROSOFT_GRAPH_SCOPE=https://graph.microsoft.com/.default

# Anthropic Claude API
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
